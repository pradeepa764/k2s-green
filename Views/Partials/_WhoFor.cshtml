@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@using Umbraco.Cms.Core.Models.Blocks
@using Umbraco.Cms.Core.Models.PublishedContent

@{
    var tabs = Model.Value<IEnumerable<BlockListItem>>("consultationTab");
    var tabCount = tabs?.Count() ?? 0;
}

 
<div class="g-bb-white defaultPadding">
    <div class="k2s-green-container consultant-service">
        <div class="ant-row css-240cud" style="justify-content: center;">
            <div class="ant-col ant-col-xs-24 ant-col-md-12  css-240cud" style="padding-left: 8px; padding-right: 8px; text-align:center;">
                <div class="header-title center">
                    <h2>Who Is Our Consultation Service For?</h2>
                    <p class="pdt20">Our services are designed for anyone ready to take control of their energy future:</p>
                </div>
            </div>
        </div>
    </div>
</div>
    <div class="k2s-green-container consultant-service">
        @if (tabs != null && tabs.Any())
        {
            <div class="k2s-green-container inner tab">
                <!-- TAB HEADERS -->
                <div class="customTabWrapper consultation">
                    <ul class="tab-list tablength-@tabCount">
                        @for (int i = 0; i < tabCount; i++)
                        {
                            var tab = tabs.ElementAt(i);
                            var tabTitle = tab.Content.Value<string>("tabTitle");
                            <li class="@(i == 0 ? "selected" : "")" data-tab="tab-@i">@tabTitle</li>
                        }
                    </ul>
                </div>

                <!-- TAB CONTENT -->
                <div class="tab-content">
                    @for (int i = 0; i < tabCount; i++)
                    {
                        var tab = tabs.ElementAt(i);
                        var tabTitle = tab.Content.Value<string>("tabTitle");
                        var tabList = tab.Content.Value<string>("tabList");
                        var tabImage = tab.Content.Value<IPublishedContent>("tabImage");

                        <div id="tab-@i" class="aboutcontent @(i == 0 ? "selected" : "hidden")">
                            <div class="ant-row our_consultation css-240cud" style="margin-left: -8px; margin-right: -8px;">
                                <!-- LEFT: TEXT -->
                                <div class="ant-col textWrapper ant-col-xs-24 ant-col-md-12 css-240cud" style="padding-left: 8px; padding-right: 8px;">
                                    <div class="flexbox column">
                                        <div class="header-title black">
                                            <h2>@tabTitle</h2>
                                        </div>
                                        <div class="listing">
                                            <ul class="details-list gray">
                                                @foreach (var line in tabList?.Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries) ?? Enumerable.Empty<string>())
                                                {
                                                    <li>@line</li>
                                                }
                                            </ul>
                                        </div>
                                    </div>
                                </div>

                                <!-- RIGHT: IMAGE -->
                                <div class="ant-col imageWrapper ant-col-xs-24 ant-col-md-12 css-240cud" style="padding-left: 8px; padding-right: 8px;">
                                    @if (tabImage != null)
                                    {
                                        <img alt="@tabTitle" src="@tabImage.Url()" />
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>
<script>
document.addEventListener("DOMContentLoaded", function () {

    const wrapper = document.querySelector(".customTabWrapper.consultation");
    const tabList = wrapper?.querySelector(".tab-list");
    const tabs = tabList?.querySelectorAll("li");
    const tabLinks = tabs;
    const tabContents = document.querySelectorAll(".tab-content .aboutcontent");

    if (!wrapper || !tabList || !tabs.length) return;

    /* -----------------------------
       TAB CLICK LOGIC (ALL SCREENS)
    ----------------------------- */
    tabLinks.forEach((link, index) => {
        link.addEventListener("click", function () {
            tabLinks.forEach(l => l.classList.remove("selected"));
            tabContents.forEach(c => c.classList.remove("selected"));

            this.classList.add("selected");
            tabContents[index].classList.add("selected");

            if (window.innerWidth <= 575) {
                scrollToTab(this);
            }
        });
    });

    /* -----------------------------
       MOBILE SCROLL LOGIC
    ----------------------------- */
    let mainTabWidth = 0;
    const gap = 12; // space between tabs

    function enableMobileTabs() {
        const wrapperWidth = wrapper.offsetWidth;

        // Each tab 75% of wrapper, next tab partially visible
        mainTabWidth = Math.floor(wrapperWidth * 0.75);

        tabList.style.display = "flex";
        tabList.style.overflowX = "auto";
        tabList.style.scrollBehavior = "smooth";
        tabList.style.padding = "0";
        tabList.style.margin = "0";

        tabs.forEach(tab => {
            tab.style.flex = `0 0 ${mainTabWidth}px`;
            tab.style.maxWidth = `${mainTabWidth}px`;
            tab.style.marginRight = `${gap}px`;
            tab.style.whiteSpace = "normal";
            tab.style.textAlign = "center";
        });

        // Scroll to active tab
        const active = tabList.querySelector(".selected") || tabs[0];
        setTimeout(() => scrollToTab(active), 100);
    }

    /* -----------------------------
       DESKTOP RESET (CRITICAL)
    ----------------------------- */
    function disableMobileTabs() {
        tabList.removeAttribute("style");

        tabs.forEach(tab => {
            tab.removeAttribute("style");
        });
    }

    /* -----------------------------
       SCROLL TO TAB FUNCTION
    ----------------------------- */
    function scrollToTab(tab) {
        const index = Array.from(tabs).indexOf(tab);
        const scrollLeft = index * (mainTabWidth + gap);
        tabList.scrollTo({
            left: scrollLeft,
            behavior: "smooth"
        });
    }

    /* -----------------------------
       INIT + RESIZE HANDLER
    ----------------------------- */
    function handleResize() {
        if (window.innerWidth <= 575) {
            enableMobileTabs();
        } else {
            disableMobileTabs(); // 👈 restore desktop view
        }
    }

    handleResize();
    window.addEventListener("resize", handleResize);

});
</script>



<style>
    .tab-content .aboutcontent {
        display: none; /* Hide all content by default */
    }

        .tab-content .aboutcontent.selected {
            display: block; /* Show content for selected tab */
        }

    .tab-list li.selected {
        font-weight: bold;
        color: #007BFF; /* Highlight color for selected tab */
    }

    .tab-list li {
        cursor: pointer;
        padding: 10px;
        display: inline-block; /* Make the tabs inline */
    }
</style>
