@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@using Umbraco.Cms.Core.Models.Blocks
@using Umbraco.Extensions
@using Umbraco.Cms.Core.Models.PublishedContent

@{
    var offerings = Model.Value<BlockListModel>("coreOfferings");
    var offeringsTitle = Model.Value<string>("offeringsTitle");
    var offeringsDescription = Model.Value<string>("offeringsDescription");
}

<div class="core-offering">
    <div class="k2s-green-container defaultPadding">

        <!-- ================= TITLE + DESCRIPTION ================= -->
        <div class="ant-row css-240cud" style="margin-left:-8px;margin-right:-8px;">
            <div class="ant-col gutter-row coltype ant-col-xs-24 ant-col-md-12 css-240cud" style="padding-left: 8px;padding-right: 8px">
                @if (!string.IsNullOrWhiteSpace(offeringsTitle))
                {
                    <div class="header-title black">
                        <h2>@offeringsTitle</h2>
                    </div>
                }
            </div>
            <div class="ant-col gutter-row coltype  ant-col-xs-24 ant-col-md-12 css-240cud" style="padding-left: 8px; padding-right: 8px;">
                @if (!string.IsNullOrWhiteSpace(offeringsDescription))
                {
                    <div class="header-title black">
                        @Html.Raw(offeringsDescription)
                    </div>
                }
            </div>
        </div>

        <!-- ================= SLIDER ================= -->
        @if (offerings != null && offerings.Any())
        {
            <div class="core-slider-wrapper" style="position:relative;">

                <!-- NEXT ARROW ONLY -->
                <button class="custom-arrow next-arrow" type="button"></button>

                <!-- SLIDER -->
                <div id="core-slider" class="carousel-lists">
                    @foreach (var item in offerings)
                    {
                        var title = item.Content.Value<string>("title");
                        var image = item.Content.Value<IPublishedContent>("image");
                        var imageUrl = image?.Url() ?? "";

                        <!-- FIXED WIDTH REQUIRED FOR VARIABLE WIDTH -->
                        <article class="carousel-item" style="width:301px">
                            <div class="img-wrapper">
                                @if (!string.IsNullOrWhiteSpace(imageUrl))
                                {
                                    <img src="@imageUrl" alt="@title" />
                                }
                            </div>
                            <p class="f32">@title</p>
                        </article>
                    }
                </div>
            </div>
        }
    </div>
</div>
<script>
$(document).ready(function () {

    var $slider = $('#core-slider');

    if ($slider.length && !$slider.hasClass('slick-initialized')) {

        $slider.slick({
            infinite: true,
            slidesToScroll: 1,
            variableWidth: true,        // ✅ REQUIRED for fixed-width slides
            arrows: true,
            prevArrow: false,           // 🔴 NO PREV
            nextArrow: $('.next-arrow'),
            dots: false,
    
            autoplay: true,
            autoplaySpeed: 3000,
            speed: 600,
            pauseOnHover: true,
            pauseOnFocus: false,
            responsive: [
                {
                    breakpoint: 1200,
                    settings: { arrows: true }
                },
                {
                    breakpoint: 992,
                    settings: { arrows: true }
                },
                {
                    breakpoint: 768,
                    settings: { arrows: false }
                }
            ]
        });
    }
});
</script>
<style>
    /* Hide overflow correctly */
.core-slider-wrapper {
    overflow: hidden;
}


.core-offering .header-title {
    margin-bottom: 40px;
}



/* Mobile fix for variableWidth slick */
@@media (max-width: 768px) {
    #core-slider .slick-slide {
        width: auto !important; 
        /* 👈 critical */
    }
}
  
</style>