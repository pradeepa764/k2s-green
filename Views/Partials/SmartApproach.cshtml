@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.PublishedContent.IPublishedContent>
@using Umbraco.Cms.Core.Models.PublishedContent
@using Umbraco.Extensions

@{
    var subtitle = Model.Value<string>("subHeading");
    var heading = Model.Value<string>("heading");
    var buttonText = Model.Value<string>("ctaText");
    var buttonLink = Model.Value<IPublishedContent>("ctaLink");
    var images = Model.Value<IEnumerable<IPublishedContent>>("images");
    var imageList = images?.Take(4).ToList() ?? new List<IPublishedContent>();
}

<div class="smart-approach default">
    <div class="k2s-green-container defaultPadding">

        @* Subtitle *@
        @if (!string.IsNullOrWhiteSpace(subtitle))
        {
            <h5 data-aos="fade-up" data-aos-anchor-placement="top-center" class="aos-init aos-animate">
                @subtitle
            </h5>
        }

        <div class="header-title white">

            @* Heading *@
            @if (!string.IsNullOrWhiteSpace(heading))
            {
                <h2 data-aos="fade-up" data-aos-anchor-placement="top-center" class="aos-init aos-animate">
                    @Html.Raw(heading)
                </h2>
            }

            @* CTA Button *@
            @if (buttonLink != null && !string.IsNullOrWhiteSpace(buttonText))
            {
                <a type="primary"
                   class="morebutton"
                   href="@buttonLink.Url()"
                   target="@(buttonLink.Value<string>("target") ?? "_self")">
                    @buttonText <i class="arrow-right"></i>
                </a>
            }

            @* Floating Images (pos1–pos4) *@
            <div class="smallPic">
                @for (int i = 0; i < 4; i++)
                {
                    var imgUrl = i < imageList.Count ? imageList[i]?.Url() : null;
                    var posClass = $"pos{i + 1}";
                    <div class="pic @posClass aos-init aos-animate"
                         data-aos="fade-up"
                         data-aos-duration="100"
                         data-aos-offset="-200"
                         data-aos-anchor-placement="top-center"
                         style="@(imgUrl != null ? $"background-image:url('{imgUrl}')" : "")">
                    </div>
                }
            </div>
        </div>
    </div>
</div>
