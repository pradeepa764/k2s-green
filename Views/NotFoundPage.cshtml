@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage

@{
	Layout = "Master1.cshtml";
}


   
<div class="bgnotFound">
   <div class="landing-screen  k2s-green-container defaultPadding_top0">  
        <div class="not-found">
            <div class="not-found-content">
                <div class="ant-row css-240cud" style="margin-left: -8px; margin-right: -8px; row-gap: 16px;">
                    <div class="ant-col ant-col-xs-24 ant-col-md-24 css-240cud" style="padding-left: 8px; padding-right: 8px;">

                        <div class="notfound"></div>

                        <div class="header-title center">
                            <h1 class="title-center">
                                <span style="color: rgb(203, 9, 105);">404</span>
                                @Model.Value("pageTitle")
                            </h1>
                            <p>@Model.Value("description")</p>
                        </div>

                        <div class="header-title center mt50">
                            <a class="morebutton" href="/">
                                @Model.Value("homeButtonText") <i class="arrow-right"></i>
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
  
<style>
  
.bgnotFound .notfound {
    background: url("/media/ryefdywp/notfound04e196c5.png") no-repeat center;
    background-size: contain;
    width: 100%;
    height: 550px;
}

bgnotFound .morebutton {
    width: 160px;
    display: flex;
    align-items: center;
    height: auto;
    margin: 0 auto;
}
@@media (max-width: 980px) {
    .bgnotFound .morebutton {
    width:186px;
    height:auto;
        display: flex;
        align-items: center;
        margin: 0 auto;
    }
}
</style>

