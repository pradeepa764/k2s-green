@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<IPublishedContent>
@{
    Layout = "Master1.cshtml";

    var title = Model.Value<string>("blogTitle");
    var image = Model.Value<IPublishedContent>("blogImage");
    var paragraph = Model.Value<string>("paragraph");
}

<section class="landing-screen wind defaultPaddingBanner">
    <div class="k2s-green-container inner alltab">

        <div class="header-title center" data-aos="fade-up">
            <h1>
                @Model.Value("blogTitle")
                <span style="color: rgb(203, 9, 105);">
                    @Model.Value("blogTitleHighlighted")
                </span>
            </h1>
        </div>

        <div class="solution-single">

            @if (image != null)
            {
                <div class="solution-image">
                    <img src="@image.Url()" alt="@title" />
                </div>
            }

            <div class="solution-content">
                @Html.Raw(paragraph)
            </div>

        </div>

    </div>
</section>

<style>
/* Section heading */
.solution-single h1,
.header-title h1 {
    font-size: 72px;
    margin: 0;
    font-weight: 300;
    font-family: "F37 Ginger";
    line-height: 96px;
}

/* Image wrapper */
.solution-image {
    text-align: center;
    margin-bottom: 40px;
}


/* Paragraph/content */
.solution-content {
    font-size: 18px;
    line-height: 1.7;
    color: #333;
}

/* Responsive */
@@media (max-width: 1024px) {
    .header-title h1 {
        font-size: 40px;
        line-height: 50px;
    }
    .solution-content {
        font-size: 16px;
    }
}

@@media (max-width: 768px) {
    .header-title h1 {
        font-size: 28px;
        line-height: 36px;
    }

    .solution-content {
        font-size: 15px;
    }
}
</style>
